# Supabase público usado no navegador para login
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLE_AQUI_A_ANON_KEY_DO_SUPABASE

# Supabase server-side. Nunca expor no navegador.
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_A_SERVICE_ROLE_KEY_DO_SUPABASE

# URL do site para links absolutos em mensagens e recuperação de senha.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Token opcional de emergência para a área gestão.
# Com Supabase/Auth configurado, o ideal é usar perfis gestao/cliente.
ADMIN_ACCESS_TOKEN=troque-este-token
